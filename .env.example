APP_NAME=CyberScan Portal API
APP_VERSION=4.0.0

CORS_ORIGINS=http://localhost:3000

UPLOAD_DIR=uploads
DB_PATH=scans.db

VT_API_KEY=
VT_URL=https://www.virustotal.com/vtapi/v2/file/report

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

HOST=0.0.0.0
PORT=8000
RELOAD=true

NEXT_PUBLIC_API_URL=http://localhost:8000

# Caddy reverse proxy — set domain for production HTTPS
# Local:      :80   (HTTP, default)
# Production: yourdomain.com  (auto HTTPS via Let's Encrypt)
SITE_ADDRESS=:80

# Grafana monitoring dashboard
GF_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=http://localhost/grafana/